{
  "edit_predictions": {
    "allow_data_collection": "no",
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
      "default_config_options": {
        "model": "claude-sonnet-4.6",
        "allow_all": "on",
      },
    },
  },
  "agent": {
    "notify_when_agent_waiting": "never",
    "enable_feedback": false,
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "terminal": {
          "always_deny": [
            { "pattern": "git commit*" },
            { "pattern": "git add*" },
            { "pattern": "git rm*" },
            { "pattern": "git mv*" },
            { "pattern": "git reset*" },
            { "pattern": "git revert*" },
            { "pattern": "git rebase*" },
            { "pattern": "git merge*" },
            { "pattern": "git cherry-pick*" },
            { "pattern": "git stash*" },
            { "pattern": "git checkout*" },
            { "pattern": "git switch*" },
            { "pattern": "git tag*" },
            { "pattern": "git push*" },
            { "pattern": "git remote remove*" },
            { "pattern": "git remote prune*" },
            { "pattern": "git remote set-head*" },
            { "pattern": "git update-ref*" },
            { "pattern": "git reflog expire*" },
            { "pattern": "git filter-branch*" },
            { "pattern": "git filter-repo*" },
            { "pattern": "git gc --prune*" },
            { "pattern": "git reflog delete*" },
            { "pattern": "git symbolic-ref*" },
            { "pattern": "git bisect*" },
            { "pattern": "git submodule deinit*" },
            { "pattern": "git submodule update*" },
            { "pattern": "git submodule sync*" },
            { "pattern": "git submodule foreach*" },
            { "pattern": "git notes add*" },
            { "pattern": "git notes remove*" },
            { "pattern": ".*\\.git(?:/.*)?" },
          ],
        },
      },
    },
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "proxy": "",
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": false,
    "show_branch_status_icon": true,
  },
  "diagnostics": {
    "button": true,
  },
  "terminal": {
    "dock": "bottom",
    "button": true,
  },
  "status_bar": {
    "active_language_button": true,
  },
  "toolbar": {
    "code_actions": false,
  },
  "auto_signature_help": true,
  "scroll_beyond_last_line": "one_page",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "hide_root": true,
    "diagnostic_badges": false,
    "bold_folder_labels": false,
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "button": false,
  },
  "soft_wrap": "editor_width",
  "git_panel": {
    "dock": "left",
    "tree_view": false,
  },
  "vim_mode": true,
  "buffer_font_family": ".ZedMono",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "icon_theme": "Catppuccin Mocha",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
}
